{
  "name": "@reelkit/react-stories-player",
  "version": "0.2.2",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "!dist/package.json",
    "!dist/README.md",
    "!**/*.tsbuildinfo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/KonstantinKai/reelkit.git",
    "directory": "packages/reelkit-react-stories-player"
  },
  "bugs": "https://github.com/KonstantinKai/reelkit/issues",
  "homepage": "https://reelkit.dev/docs/stories-player",
  "funding": {
    "type": "buymeacoffee",
    "url": "https://buymeacoffee.com/konstantinkai"
  },
  "description": "Instagram-style stories player overlay for React with flip transitions and auto-advance",
  "license": "MIT",
  "keywords": [
    "react",
    "stories",
    "instagram-stories",
    "stories-player",
    "fullscreen",
    "swipe",
    "touch",
    "auto-advance",
    "flip-transition",
    "react-component",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@reelkit/react": "^0.6.1",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "lucide-react": ">=0.400.0"
  },
  "dependencies": {
    "@reelkit/stories-core": "^0.1.4"
  }
}
