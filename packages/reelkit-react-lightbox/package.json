{
  "name": "@reelkit/react-lightbox",
  "version": "0.5.0",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "!dist/package.json",
    "!dist/README.md",
    "!**/*.tsbuildinfo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/KonstantinKai/reelkit.git",
    "directory": "packages/reelkit-react-lightbox"
  },
  "bugs": "https://github.com/KonstantinKai/reelkit/issues",
  "homepage": "https://reelkit.dev/docs/lightbox",
  "funding": {
    "type": "buymeacoffee",
    "url": "https://buymeacoffee.com/konstantinkai"
  },
  "description": "Full-screen image and video gallery lightbox for React with touch gestures, transitions, and render props",
  "license": "MIT",
  "keywords": [
    "react",
    "lightbox",
    "image-gallery",
    "fullscreen",
    "swipe",
    "touch",
    "gallery",
    "video-player",
    "photo-viewer",
    "react-component",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@reelkit/react": "^0.6.1",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "lucide-react": ">=0.400.0"
  }
}
