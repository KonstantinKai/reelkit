{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "outDir": "../dist/out-tsc",
    "types": [
      "node",
      "@nx/react/typings/cssmodule.d.ts",
      "@nx/react/typings/image.d.ts",
      "vite/client"
    ]
  },
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.tsx",
    "src/**/*.spec.js",
    "src/**/*.test.js",
    "src/**/*.spec.jsx",
    "src/**/*.test.jsx",
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts"
  ],
  "include": ["src/**/*.js", "src/**/*.jsx", "src/**/*.ts", "src/**/*.tsx"],
  "references": [
    {
      "path": "../../packages/reelkit-core/tsconfig.lib.json"
    },
    {
      "path": "../../packages/reelkit-react-reel-player/tsconfig.lib.json"
    },
    {
      "path": "../../packages/reelkit-example-data/tsconfig.lib.json"
    },
    {
      "path": "../../packages/reelkit-react-lightbox/tsconfig.lib.json"
    },
    {
      "path": "../../packages/reelkit-react/tsconfig.lib.json"
    }
  ]
}
