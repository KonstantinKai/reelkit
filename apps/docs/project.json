{
  "name": "docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/docs/src",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project docs --web",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "commands": [
          "npx react-router build",
          "rm -rf ../dist/docs && mkdir -p ../dist/docs && cp -R build/client/. ../dist/docs/",
          "cp ../dist/docs/__spa-fallback.html ../dist/docs/404.html",
          "rm -rf build"
        ],
        "cwd": "apps/docs",
        "parallel": false
      },
      "outputs": ["{workspaceRoot}/apps/dist/docs"],
      "cache": true
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx react-router dev",
        "cwd": "apps/docs"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "npx serve ../dist/docs -l 4200",
        "cwd": "apps/docs"
      }
    }
  }
}
