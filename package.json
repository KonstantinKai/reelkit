{
  "name": "@reelkit/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "build": "npx nx run-many -t build --no-tui",
    "fmt:chk": "npx nx format:check",
    "fmt": "npx nx format",
    "lint": "npx nx run-many -t lint --no-tui",
    "typecheck": "npx nx run-many -t typecheck --no-tui",
    "check": "npm run fmt:chk && npm run lint && npm run typecheck",
    "test": "npx nx run-many -t test --no-tui",
    "e2e": "npx nx run-many -t e2e --no-tui",
    "update-sizes": "node scripts/update-sizes.mjs",
    "release:npm": "which op > /dev/null 2>&1 && op run --env-file=.env.op -- npx nx release publish || echo '1Password CLI (op) is not installed. Install it from https://1password.com/downloads/command-line/'"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KonstantinKai/reelkit.git"
  },
  "bugs": "https://github.com/KonstantinKai/reelkit/issues",
  "homepage": "https://reelkit.dev",
  "private": true,
  "dependencies": {
